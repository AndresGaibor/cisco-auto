{
  "name": "VLAN Demo",
  "description": "Demo simple con VLAN 10, 20 y 30, trunk y router-on-a-stick",
  "devices": [
    { "name": "R1", "type": "router", "x": 120, "y": 80 },
    { "name": "SW-CORE", "type": "switch", "x": 260, "y": 80 },
    { "name": "SW-ACC1", "type": "switch", "x": 400, "y": 40 },
    { "name": "SW-ACC2", "type": "switch", "x": 400, "y": 120 },
    { "name": "PC-ADMIN", "type": "pc", "x": 560, "y": 30 },
    { "name": "PC-USERS", "type": "pc", "x": 560, "y": 110 },
    { "name": "PC-GUEST", "type": "pc", "x": 560, "y": 150 }
  ],
  "vlans": [
    { "id": 10, "name": "ADMIN" },
    { "id": 20, "name": "USERS" },
    { "id": 30, "name": "GUEST" }
  ],
  "links": [
    { "from": "R1", "fromInterface": "g0/0", "to": "SW-CORE", "toInterface": "g0/1", "type": "ethernet" },
    { "from": "SW-CORE", "fromInterface": "g0/2", "to": "SW-ACC1", "toInterface": "g0/1", "type": "ethernet" },
    { "from": "SW-CORE", "fromInterface": "g0/3", "to": "SW-ACC2", "toInterface": "g0/1", "type": "ethernet" },
    { "from": "SW-ACC1", "fromInterface": "f0/1", "to": "PC-ADMIN", "toInterface": "eth0", "type": "ethernet" },
    { "from": "SW-ACC2", "fromInterface": "f0/1", "to": "PC-USERS", "toInterface": "eth0", "type": "ethernet" },
    { "from": "SW-ACC2", "fromInterface": "f0/2", "to": "PC-GUEST", "toInterface": "eth0", "type": "ethernet" }
  ],
  "notes": [
    "Trunk entre SW-CORE y switches de acceso",
    "Router-on-a-stick en R1",
    "VLAN 10 para administración",
    "VLAN 20 para usuarios",
    "VLAN 30 para invitados"
  ]
}
