{
  "name": "@cisco-auto/cli",
  "version": "0.2.0",
  "description": "CLI de cisco-auto",
  "type": "module",
  "bin": {
    "cisco-auto": "./src"
  },
  "main": "./src",
  "scripts": {
    "start": "bun run src",
    "dev": "bun run --watch src",
    "build": "bun build ./src --outdir ./dist --target bun",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cisco-auto/lab-model": "workspace:*",
    "@cisco-auto/device-catalog": "workspace:*",
    "@cisco-auto/topology": "workspace:*",
    "@cisco-auto/core": "workspace:*",
    "@cisco-auto/api": "workspace:*",
    "@cisco-auto/bridge": "workspace:*",
    "@cisco-auto/templates": "workspace:*",
    "@cisco-auto/tools": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
