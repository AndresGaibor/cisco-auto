{
  "name": "@cisco-auto/pt-cli",
  "version": "0.2.0",
  "description": "CLI de cisco-auto",
  "type": "module",
  "bin": {
    "cisco-auto": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/ --max-warnings 0",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "build": "echo no build needed"
  },
  "dependencies": {
    "@cisco-auto/file-bridge": "workspace:*",
    "@cisco-auto/kernel": "workspace:*",
    "@cisco-auto/network-intent": "workspace:*",
    "@cisco-auto/pt-control": "workspace:*",
    "@cisco-auto/pt-memory": "workspace:*",
    "@cisco-auto/pt-runtime": "workspace:*",
    "@cisco-auto/terminal-contracts": "workspace:*",
    "@cisco-auto/ios-primitives": "workspace:*",
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
