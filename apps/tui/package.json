{
  "name": "@cisco-auto/tui",
  "version": "0.1.0",
  "description": "Terminal User Interface para Cisco Auto",
  "type": "module",
  "main": "./src/index.tsx",
  "types": "./src/index.tsx",
  "bin": {
    "cisco-tui": "./bin/cisco-tui.ts"
  },
  "scripts": {
    "start": "bun run ./src/cli.ts",
    "build": "bun build ./src/index.tsx --outdir ./dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cisco-auto/lab-model": "workspace:*",
    "@cisco-auto/sim-engine": "workspace:*",
    "@cisco-auto/sim-runtime": "workspace:*",
    "ink": "^6.8.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "typescript": "^5"
  }
}