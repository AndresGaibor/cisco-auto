import { isToolResultSuccess } from '@cisco-auto/core';
import { describe, test, expect } from 'bun:test';
import { ptListDevicesTool, deviceCatalog } from '@cisco-auto/core/tools';

describe('pt_list_devices', () => {
  test('retorna todos los dispositivos sin filtro', async () => {
    const result = await ptListDevicesTool.handler({}, {} as any);

    expect(isToolResultSuccess(result)).toBe(true);
    if (isToolResultSuccess(result)) {
      const data = result.data as { devices: unknown[]; total: number };
      expect(data.devices).toHaveLength(deviceCatalog.length);
      expect(data.total).toBe(deviceCatalog.length);
    }
  });

  test('filtra por tipo router', async () => {
    const result = await ptListDevicesTool.handler({ type: 'router' }, {} as any);

    expect(isToolResultSuccess(result)).toBe(true);
    if (isToolResultSuccess(result)) {
      const data = result.data as { devices: { type: string }[] };
      expect(data.devices.every((d: { type: string }) => d.type === 'router')).toBe(true);
    }
  });

  test('filtra por tipo switch', async () => {
    const result = await ptListDevicesTool.handler({ type: 'switch' }, {} as any);

    expect(isToolResultSuccess(result)).toBe(true);
    if (isToolResultSuccess(result)) {
      const data = result.data as { devices: { type: string }[] };
      expect(data.devices.every((d: { type: string }) => d.type === 'switch')).toBe(true);
    }
  });

  test('incluye metadatos correctos', async () => {
    const result = await ptListDevicesTool.handler({}, {} as any);

    expect(isToolResultSuccess(result)).toBe(true);
    if (isToolResultSuccess(result)) {
      expect(result.metadata?.itemCount).toBe(deviceCatalog.length);
    }
  });
});
