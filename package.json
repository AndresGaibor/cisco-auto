{
  "name": "cisco-auto",
  "version": "0.2.0",
  "description": "Control en tiempo real de Packet Tracer - Automation toolkit Bun-first",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun run --cwd apps/pt-cli start",
    "dev": "bun run --cwd apps/pt-cli dev",
    "test": "bun test",
    "build": "bun run build:packages && bun run build:apps",
    "build:packages": "bun run --filter './packages/*' build",
    "build:apps": "bun run --filter './apps/*' build",
    "typecheck": "bun run --filter './packages/*' typecheck && bun run --filter './apps/*' typecheck",
    "cisco-auto": "bun run --cwd apps/pt-cli start",
    "pt": "bun run packages/pt-control/bin/dev.js",
    "pt:build": "bun run --filter '@cisco-auto/pt-runtime' build && bun run --filter '@cisco-auto/file-bridge' build && bun run --filter '@cisco-auto/pt-control' build",
    "pt:generate": "bun run --filter '@cisco-auto/pt-control' runtime:generate",
    "pt:test": "bun run --cwd apps/pt-cli test",
    "bridge:dev": "bun run --cwd packages/http-bridge dev",
    "bridge:start": "bun run --cwd packages/http-bridge start"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "@cisco-auto/core": "workspace:*",
    "@cisco-auto/file-bridge": "workspace:*",
    "@cisco-auto/ios-domain": "workspace:*",
    "@cisco-auto/pt-control": "workspace:*",
    "@cisco-auto/types": "workspace:*",
    "fast-xml-parser": "^5.5.6",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
