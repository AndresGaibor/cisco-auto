{
  "name": "cisco-auto",
  "version": "0.2.0",
  "description": "Control en tiempo real de Packet Tracer - Automation toolkit Bun-first",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun run --cwd apps/pt-cli start",
    "dev": "bun run --cwd apps/pt-cli dev",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "pt": "bun run --cwd apps/pt-cli start",
    "pt:build": "bun run --cwd packages/pt-runtime src/index.ts deploy",
    "pt:generate": "bun run --cwd packages/pt-runtime src/index.ts generate",
    "pt:validate": "bun run --cwd packages/pt-runtime src/index.ts validate",
    "pt:deploy": "bun run --cwd packages/pt-runtime src/index.ts deploy"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "@cisco-auto/core": "workspace:*",
    "@cisco-auto/file-bridge": "workspace:*",
    "@cisco-auto/ios-domain": "workspace:*",
    "@cisco-auto/kernel": "workspace:*",
    "@cisco-auto/pt-control": "workspace:*",
    "@cisco-auto/types": "workspace:*",
    "fast-xml-parser": "^5.5.6",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
