{
  "name": "cisco-auto",
  "version": "0.2.0",
  "description": "Control en tiempo real de Packet Tracer - Automation toolkit Bun-first",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "turbo run start --filter=pt-cli",
    "dev": "turbo run dev --filter=pt-cli",
    "test": "bun test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "pre-release-check": "turbo run pre-release-check",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "pt": "bun run --cwd apps/pt-cli start",
    "pt:build": "cd packages/pt-runtime && bun src/index.ts deploy",
    "pt:generate": "cd packages/pt-runtime && bun src/index.ts generate",
    "pt:validate": "cd packages/pt-runtime && bun src/index.ts validate",
    "pt:deploy": "cd packages/pt-runtime && bun src/index.ts deploy"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6",
    "typescript": "^5"
  },
  "dependencies": {
    "@cisco-auto/core": "workspace:*",
    "@cisco-auto/file-bridge": "workspace:*",
    "@cisco-auto/ios-domain": "workspace:*",
    "@cisco-auto/kernel": "workspace:*",
    "@cisco-auto/pt-control": "workspace:*",
    "@cisco-auto/types": "workspace:*",
    "fast-xml-parser": "^5.5.6",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
