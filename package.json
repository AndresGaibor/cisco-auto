{
  "name": "cisco-auto",
  "version": "0.2.0",
  "description": "Control en tiempo real de Packet Tracer - Automation toolkit Bun-first",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "turbo run start --filter=pt-cli",
    "dev": "turbo run dev --filter=pt-cli",
    "test": "bun test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "pre-release-check": "turbo run pre-release-check",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "pt": "bun run --cwd apps/pt-cli start",
    "pt build": "bun run --cwd packages/pt-control scripts/build.ts",
    "pt:verify:real:switching-advanced": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile switching-advanced",
    "pt:verify:real:routing-intervlan": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile routing-intervlan",
    "pt:verify:real:dhcp-core": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile dhcp-core",
    "pt:verify:real:interactive-resilience": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile interactive-resilience",
    "pt:verify:real:switching-resilience": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile switching-resilience",
    "pt:verify:real:etherchannel-core": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile etherchannel-core",
    "pt:verify:real:dynamic-routing-core": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile dynamic-routing-core",
    "pt:verify:real:acl-nat-core": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile acl-nat-core",
    "pt:verify:real:services-advanced": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile services-advanced",
    "pt:verify:real:stability-regression": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile stability-regression",
    "pt:verify:real:security-core": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile security-core",
    "pt:verify:real:ipv6-core": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile ipv6-core",
    "pt:verify:real:hsrp-core": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile hsrp-core",
    "pt:verify:real:wireless-core": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile wireless-core",
    "pt:verify:real:terminal-regression": "bun run packages/pt-control/src/verification/cli/pt-real-verify-cli.ts --profile terminal-regression"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6",
    "typescript": "^5"
  },
  "dependencies": {
    "@cisco-auto/file-bridge": "workspace:*",
    "@cisco-auto/ios-domain": "workspace:*",
    "@cisco-auto/kernel": "workspace:*",
    "@cisco-auto/pt-control": "workspace:*",
    "@cisco-auto/types": "workspace:*",
    "fast-xml-parser": "^5.5.6",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
