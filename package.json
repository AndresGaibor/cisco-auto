{
  "name": "cisco-auto",
  "version": "0.2.0",
  "description": "Plataforma de simulación de redes Cisco con TUI",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun run --cwd apps/cli start",
    "dev": "bun run --cwd apps/cli dev",
    "test": "bun test",
    "build": "bun run build:packages && bun run build:apps",
    "build:packages": "bun run --filter './packages/*' build",
    "build:apps": "bun run --filter './apps/*' build",
    "typecheck": "bun run --filter './packages/*' typecheck && bun run --filter './apps/*' typecheck",
    "cisco-auto": "bun run --cwd apps/cli start",
    "tui": "bun run --cwd apps/tui start",
    "sim": "bun run --cwd packages/sim-engine test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/inquirer": "^9.0.9",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-xml-parser": "^5.5.6",
    "inquirer": "^13.3.2",
    "js-yaml": "^4.1.1",
    "node-ssh": "^13.2.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}