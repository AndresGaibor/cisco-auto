{
  "name": "cisco-auto",
  "version": "0.2.0",
  "description": "Manipulación de archivos PKA de Cisco Packet Tracer",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun run --cwd apps/cli start",
    "dev": "bun run --cwd apps/cli dev",
    "test": "bun test",
    "build": "bun run build:packages && bun run build:apps",
    "build:packages": "bun run --filter './packages/*' build",
    "build:apps": "bun run --filter './apps/*' build",
    "typecheck": "bun run --filter './packages/*' typecheck && bun run --filter './apps/*' typecheck",
    "cisco-auto": "bun run --cwd apps/cli start",
    "sim": "bun run --cwd packages/sim-engine test",
    "pt": "bun run --cwd packages/pt-control src/cli/index.ts",
    "pt:test": "bun run --cwd packages/pt-control test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "@cisco-auto/core": "workspace:*",
    "@cisco-auto/api": "workspace:*",
    "@cisco-auto/bridge": "workspace:*",
    "@cisco-auto/crypto": "workspace:*",
    "@cisco-auto/device-catalog": "workspace:*",
    "@cisco-auto/import-pka": "workspace:*",
    "@cisco-auto/import-yaml": "workspace:*",
    "@cisco-auto/lab-model": "workspace:*",
    "@cisco-auto/legacy": "workspace:*",
    "@cisco-auto/pt-control": "workspace:*",
    "@cisco-auto/sim-engine": "workspace:*",
    "@cisco-auto/sim-runtime": "workspace:*",
    "@cisco-auto/topology": "workspace:*",
    "@cisco-auto/tools": "workspace:*",
    "fast-xml-parser": "^5.5.6",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "twofish-ts": "^1.0.2",
    "zod": "^4.3.6"
  }
}