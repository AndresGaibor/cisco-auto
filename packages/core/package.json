{
  "name": "@cisco-auto/core",
  "version": "0.1.0",
  "description": "Core networking logic for cisco-auto",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "bun build ./src --outdir ./dist --target bun",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./parser/*": "./src/parser/*",
    "./types/*": "./src/types/*",
    "./config-generators/*": "./src/config-generators/*",
    "./topology/*": "./src/topology/*",
    "./canonical/*": "./src/canonical/*",
    "./executor/*": "./src/executor/*",
    "./models/*": "./src/models/*",
    "./validation/*": "./src/validation/*"
  },
  "dependencies": {
    "@cisco-auto/lab-model": "workspace:*",
    "chalk": "^5.6.2",
    "node-ssh": "^13.2.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5"
  }
}
