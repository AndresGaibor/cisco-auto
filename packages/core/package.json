{
  "name": "@cisco-auto/core",
  "version": "0.1.0",
  "description": "Core networking logic for cisco-auto (includes lab-model, tools, templates)",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun build ./src --outdir ./dist --target bun --format esm && tsc --project tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./config-generators": "./dist/src/index.js",
    "./parser": "./dist/src/index.js",
    "./topology": "./dist/src/index.js",
    "./canonical": "./dist/src/index.js",
    "./executor": "./dist/src/index.js",
    "./validation": "./dist/src/index.js",
    "./tools": "./dist/src/index.js",
    "./templates": "./dist/src/index.js"
  },
  "dependencies": {
    "@cisco-auto/types": "workspace:*",
    "js-yaml": "^4.1.1",
    "node-ssh": "^13.2.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5"
  }
}
