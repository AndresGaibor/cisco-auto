{
  "name": "@cisco-auto/import-pka",
  "version": "0.1.0",
  "description": "Adapter para importar/exportar archivos PKA/PKT de Packet Tracer",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./decoder": "./src/decoder.ts",
    "./encoder": "./src/encoder.ts",
    "./adapter": "./src/adapter.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cisco-auto/lab-model": "workspace:*",
    "@cisco-auto/crypto": "workspace:*",
    "fast-xml-parser": "^5.5.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
