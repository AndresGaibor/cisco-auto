{
  "name": "@cisco-auto/import-yaml",
  "version": "0.1.0",
  "description": "Adapter para importar/exportar labs en formato YAML",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./parser": "./src/parser",
    "./serializer": "./src/serializer"
  },
  "scripts": {
    "build": "bun build ./src --outdir ./dist --target bun",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cisco-auto/lab-model": "workspace:*",
    "@cisco-auto/core": "workspace:*",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5"
  }
}
