{
  "name": "@cisco-auto/ios-domain",
  "version": "0.1.0",
  "description": "Shared IOS domain for Cisco automation",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./value-objects": "./src/value-objects/index.ts",
    "./value-objects/*": "./src/value-objects/*",
    "./parsers": "./src/parsers/index.ts",
    "./parsers/*": "./src/parsers/*",
    "./operations": "./src/operations/index.ts",
    "./operations/*": "./src/operations/*",
    "./session": "./src/session/index.ts",
    "./session/*": "./src/session/*",
    "./utils": "./src/utils/index.ts",
    "./utils/*": "./src/utils/*",
    "./capabilities": "./src/capabilities/index.ts",
    "./capabilities/*": "./src/capabilities/*",
    "./errors": "./src/errors.ts",
    "./schemas": "./src/schemas/index.ts",
    "./schemas/*": "./src/schemas/*",
    "./generators": "./src/generators/index.ts",
    "./generators/types": "./src/generators/types.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "bun test"
  },
  "dependencies": {
    "@cisco-auto/core": "workspace:*",
    "@cisco-auto/types": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
