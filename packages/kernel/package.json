{
  "name": "@cisco-auto/kernel",
  "version": "0.1.0",
  "description": "Core kernel with domain, application, and plugin API",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./domain": "./src/domain/index.ts",
    "./domain/ios": "./src/domain/ios/index.ts",
    "./domain/ios/value-objects": "./src/domain/ios/value-objects/index.ts",
    "./domain/ios/schemas": "./src/domain/ios/schemas/index.ts",
    "./domain/ios/capability-matrix": "./src/domain/ios/capability-matrix/index.ts",
    "./domain/ios/capability-matrix/*": "./src/domain/ios/capability-matrix/*.ts",
    "./domain/topology": "./src/domain/topology/index.ts",
    "./domain/lab": "./src/domain/lab/index.ts",
    "./application": "./src/application/index.ts",
    "./plugin-api": "./src/plugin-api/index.ts",
    "./plugin-api/*": "./src/plugin-api/*.ts",
    "./plugins/vlan": "./src/plugins/vlan/index.ts",
    "./plugins/vlan/*": "./src/plugins/vlan/*.ts",
    "./plugins/switching": "./src/plugins/switching/index.ts",
    "./plugins/switching/*": "./src/plugins/switching/*.ts",
    "./plugins/routing": "./src/plugins/routing/index.ts",
    "./plugins/routing/*": "./src/plugins/routing/*.ts",
    "./plugins/security": "./src/plugins/security/index.ts",
    "./plugins/security/*": "./src/plugins/security/*.ts",
    "./plugins/services": "./src/plugins/services/index.ts",
    "./plugins/services/*": "./src/plugins/services/*.ts",
    "./plugins/ipv6": "./src/plugins/ipv6/index.ts",
    "./plugins/ipv6/*": "./src/plugins/ipv6/*.ts",
    "./plugins/port-template": "./src/plugins/port-template/index.ts",
    "./plugins/port-template/*": "./src/plugins/port-template/*.ts",
    "./plugins/basic-config": "./src/plugins/basic-config/index.ts",
    "./plugins/basic-config/*": "./src/plugins/basic-config/*.ts",
    "./plugins/orchestrator": "./src/plugins/orchestrator/index.ts",
    "./plugins/orchestrator/*": "./src/plugins/orchestrator/*.ts",
    "./backends/packet-tracer": "./src/backends/packet-tracer/index.ts",
    "./backends/packet-tracer/*": "./src/backends/packet-tracer/*.ts"
  },
  "scripts": {
    "test": "bun test",
    "build": "echo no build needed"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "files": ["/src"],
  "license": "MIT"
}
