{
  "name": "@cisco-auto/pt-control-v2",
  "version": "2.0.0",
  "description": "Professional CLI for controlling Cisco Packet Tracer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pt": "./bin/run.js"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:ts": "tsc",
    "build:watch": "bun run scripts/build.ts --watch",
    "build:no-deploy": "bun run scripts/build.ts --no-deploy",
    "dev": "tsc --watch",
    "test": "bun test tests",
    "runtime:generate": "bun run scripts/build.ts --no-deploy",
    "runtime:deploy": "bun run scripts/build.ts",
    "oclif:manifest": "oclif manifest",
    "oclif:readme": "oclif readme"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@oclif/core": "^4.10.2",
    "cli-table3": "^0.6.5",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  },
  "exports": {
    ".": "./dist/index.js",
    "./controller": "./dist/controller/index.js",
    "./vdom": "./dist/vdom/index.js",
    "./parsers": "./dist/parsers/index.js",
    "./types": "./dist/types/index.js",
    "./logging": "./dist/logging/index.js"
  },
  "oclif": {
    "bin": "pt",
    "dirname": "pt-control",
    "commands": "./dist/cli/commands",
    "plugins": [],
    "topicSeparator": " ",
    "topics": {
      "device": {
        "description": "Device management commands"
      },
      "link": {
        "description": "Link management commands"
      },
      "config": {
        "description": "Configuration commands"
      },
      "runtime": {
        "description": "Runtime management commands"
      },
      "snapshot": {
        "description": "Snapshot management commands"
      },
      "record": {
        "description": "Recording commands"
      },
      "trunk": {
        "description": "Trunk port configuration commands"
      },
      "vlan": {
        "description": "VLAN configuration commands"
      },
      "ssh": {
        "description": "SSH configuration commands"
      }
    }
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cisco",
    "packet-tracer",
    "cli",
    "network",
    "automation"
  ],
  "author": "",
  "license": "MIT"
}
