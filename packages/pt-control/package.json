{
  "name": "@cisco-auto/pt-control",
  "version": "2.0.0",
  "description": "Professional CLI for controlling Cisco Packet Tracer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:ts": "tsc",
    "build:watch": "bun run scripts/build.ts --watch",
    "build:no-deploy": "bun run scripts/build.ts --no-deploy",
    "dev": "tsc --watch",
    "test": "bun test tests",
    "typecheck": "tsc --noEmit",
    "runtime:generate": "bun run scripts/build.ts --no-deploy",
    "runtime:deploy": "bun run scripts/build.ts"
  },
  "dependencies": {
    "@cisco-auto/file-bridge": "workspace:*",
    "@cisco-auto/pt-runtime": "workspace:*",
    "@cisco-auto/types": "workspace:*",
    "@inquirer/prompts": "^8.3.2",
    "cli-table3": "^0.6.5",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "typescript": "^5.4.0"
  },
  "exports": {
    ".": "./dist/index.js",
    "./controller": "./dist/controller/index.js",
    "./vdom": "./dist/vdom/index.js",
    "./parsers": "./dist/parsers/index.js",
    "./types": "./dist/types/index.js",
    "./logging": "./dist/logging/index.js"
  },
  "files": [
    "/dist"
  ],
  "keywords": [
    "cisco",
    "packet-tracer",
    "cli",
    "network",
    "automation"
  ],
  "author": "",
  "license": "MIT"
}
