{
  "name": "@cisco-auto/pt-runtime",
  "version": "0.1.0",
  "description": "Packet Tracer runtime generator - generates main.js and runtime.js for PT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./templates": "./dist/templates"
  },
  "bin": {
    "pt-runtime": "./bin/run.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "generate-models": "bun run src/scripts/generate-model-map.ts",
    "generate": "bun run src/index.ts generate",
    "deploy": "bun run src/index.ts deploy",
    "test": "bun test"
  },
  "dependencies": {
    "@cisco-auto/core": "workspace:*"
  },
  "devDependencies": {
    "@cisco-auto/pt-control": "workspace:*",
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
