{
  "name": "@cisco-auto/pt-runtime",
  "version": "0.1.0",
  "description": "Packet Tracer runtime generator - generates main.js and runtime.js for PT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./templates": "./dist/templates",
    "./value-objects": "./src/value-objects/index.ts"
  },
  "bin": {
    "pt-runtime": "./bin/run.js"
  },
  "scripts": {
    "build:lib": "tsc",
    "build:runtime": "tsc -p tsconfig.runtime.json",
    "build:runtime:watch": "tsc -p tsconfig.runtime.json --watch",
    "build": "bun run build:lib && bun run build:runtime",
    "dev:runtime": "tsc -p tsconfig.runtime.json --watch",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.runtime.json --noEmit",
    "generate-models": "bun run src/scripts/generate-model-map.ts",
    "generate": "bun run build:runtime && bun run src/index.ts generate",
    "validate": "bun run build:runtime && bun run src/index.ts validate",
    "deploy": "bun run build:runtime && bun run src/index.ts deploy",
    "test": "bun test"
  },
  "dependencies": {
    "@cisco-auto/core": "workspace:*",
    "@cisco-auto/types": "workspace:*"
  },
  "devDependencies": {
    "@cisco-auto/pt-control": "workspace:*",
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
