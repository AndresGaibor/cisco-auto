{
  "compilerOptions": {
    "target": "ES5",
    "lib": ["ES5"],
    "module": "esnext",
    "moduleResolution": "node",
    "outDir": "./generated",
    "rootDir": "./src/runtime",
    "declaration": false,
    "sourceMap": false,
    "removeComments": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/runtime/**/*.ts"],
  "exclude": ["node_modules", "dist", "__tests__"]
}
