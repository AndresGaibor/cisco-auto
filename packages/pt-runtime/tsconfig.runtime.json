{
  "compilerOptions": {
    "target": "ES5",
    "lib": ["ES5"],
    "module": "esnext",
    "moduleResolution": "node",
    "outDir": "./generated",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": false,
    "removeComments": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "downlevelIteration": true
  },
  "include": [
    "src/runtime/**/*.ts",
    "src/handlers/**/*.ts",
    "src/utils/**/*.ts",
    "src/value-objects/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "__tests__", "templates", "scripts"]
}